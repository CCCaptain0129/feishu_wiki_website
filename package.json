{
  "name": "feishu-wiki-site-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Feishu Wiki/Docx to website content toolkit",
  "type": "module",
  "scripts": {
    "content:build": "tsx scripts/build-content.ts",
    "site:dev": "CONTENT_DIR=../../tmp/local-run-latest npm --prefix apps/site run dev -- --port 3010",
    "dev": "npm run content:build && npm run site:dev"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.20.6"
  }
  ,
  "keywords": [
    "feishu",
    "wiki",
    "docx",
    "cms",
    "nextjs"
  ],
  "license": "MIT"
}
